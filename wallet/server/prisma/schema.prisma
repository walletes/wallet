generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Wallet {
  address     String   @id
  balance     String
  healthScore Int      @default(100)
  riskLevel   String   @default("LOW")
  lastSynced  DateTime @default(now())
  rules       AutomationRule[]
}

model AutomationRule {
  id            Int      @id @default(autoincrement())
  walletAddress String
  privateKey    String   // Stores encrypted key (iv:salt:iv:tag:ciphertext)
  chain         String
  type          String   // AUTO_BURN, AUTO_RECOVERY
  active        Boolean  @default(true)
  targetBalance String?
  createdAt     DateTime @default(now())
  wallet        Wallet   @relation(fields: [walletAddress], references: [address])

  @@index([walletAddress, active])
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  wallet    String   @unique
  plan      String
  createdAt DateTime @default(now())
  usage     Int      @default(0)
  @@index([wallet])
}

/**
 * UPGRADED: Financial-grade Payment tracking.
 * Added traceId for external audits and rawAmount for blockchain precision.
 */
model Payment {
  id        String   @id @default(cuid())
  traceId   String?  @unique
  wallet    String
  txHash    String?  @unique
  amount    Float    // Display value
  rawAmount String?  // BigInt string for precise validation
  chain     String
  status    String   @default("PENDING") // PENDING, SUCCESS, FAILED
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([wallet, status])
}

model RecoveryAttempt {
  id                String   @id @default(cuid())
  traceId           String?  @unique
  walletAddress     String
  tokenCount        Int
  estimatedTotalUsd String
  status            String   // IN_PROGRESS, COMPLETED, FAILED
  createdAt         DateTime @default(now())
  @@index([walletAddress])
}

/**
 * UPGRADED: Atomic SystemLock.
 * Includes ownerId to prevent stale processes from unlocking new ones.
 */
model SystemLock {
  id        String   @id 
  isLocked  Boolean  @default(false)
  ownerId   String?  // UUID of the process currently holding the lock
  updatedAt DateTime @updatedAt
}

/**
 * DYNAMIC MONETIZATION: 30-Day Auto-Pilot.
 * This extends the ApiKey logic to handle the 0/1,000 requests limit.
 */
model ApiSubscription {
  id            String    @id @default(cuid())
  apiKeyId      String    @unique
  planType      String    @default("BASIC") // 0 Plan
  requestLimit  Int       @default(1000)
  currentUsage  Int       @default(0)
  
  // The 30-Day Window
  startsAt      DateTime  @default(now())
  endsAt        DateTime  // Logic: set to now() + 30 days on payment
  
  isActive      Boolean   @default(true)
  autoRenew     Boolean   @default(false)
  
  apiKey        ApiKey    @relation(fields: [apiKeyId], references: [id])
}

/**
 * SECURITY INTELLIGENCE: 10-10 Poison Detection.
 * Stores identified vanity spoofing patterns to protect all users/devs.
 */
model ThreatIntel {
  id          String   @id @default(cuid())
  pattern     String   @unique // The '10-10' character string or full address
  threatType  String   // POISON_ADDRESS, GAS_SIPHON, HONEYPOT
  riskLevel   Int      @default(90)
  detectedAt  DateTime @default(now())
  occurrences Int      @default(1)
  
  @@index([pattern])
}

/**
 * DELEGATED EXECUTION: Scoped Session Keys.
 * Allows the Butler to work while the user is offline without full custody.
 */
model SessionKey {
  id            String   @id @default(cuid())
  walletAddress String
  publicKey     String
  encryptedKey  String   // Scoped key (iv:salt:tag:ciphertext)
  permissions   Json     // { "burn": true, "recover": true, "maxGas": "0.01" }
  expiresAt     DateTime
  isActive      Boolean  @default(true)
  
  wallet        Wallet   @relation(fields: [walletAddress], references: [address])
  @@index([walletAddress, isActive])
}

/**
 * EXECUTION AUDIT: Simulation Logs.
 * Records every pre-flight check for the "Net-Zero" rule.
 */
model SimulationLog {
  id            String   @id @default(cuid())
  walletAddress String
  txHash        String?
  isSafe        Boolean
  riskScore     Int      // 0-100
  diff          Json?    // State changes detected
  createdAt     DateTime @default(now())

  @@index([walletAddress])
}

/**
 * ENHANCED: Forensic Simulation Metadata.
 * Stores the "Rich Data" for developer dashboards and user audits.
 */
model ForensicAudit {
  id                String   @id @default(cuid())
  walletAddress     String
  targetAddress     String   // The contract/token being interacted with
  
  // High-Level Result
  isSafe            Boolean
  riskScore         Int      // 0-100
  verdict           String   // e.g., "BLOCK_HONEYPOT", "WARN_GAS_TRAP"
  
  // Structured Forensic Data (The JSON Report)
  simulationPayload Json     // Stores internalCalls, gasEstimates, stateDiffs
  contractMetadata  Json     // Stores owner, factoryInfo, functionAnalysis
  behaviorPatterns  Json     // Stores honeypotFlag, approvalTrap, etc.
  
  createdAt         DateTime @default(now())
  
  @@index([walletAddress, targetAddress])
}

/**
 * NEW: Developer Usage Analytics.
 * Powers the "Developer Dashboard" with charts and heatmaps.
 */
model ApiAnalytics {
  id            String   @id @default(cuid())
  apiKeyId      String
  endpoint      String
  statusCode    Int
  responseTime  Int      // in milliseconds
  riskDetected  Boolean  @default(false)
  gasSaved      String?  // Total gas WIP saved the dev's user
  createdAt     DateTime @default(now())

  @@index([apiKeyId, createdAt])
}

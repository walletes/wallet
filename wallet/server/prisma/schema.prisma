generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Wallet {
  address     String   @id
  balance     String
  healthScore Int      @default(100)
  riskLevel   String   @default("LOW")
  lastSynced  DateTime @default(now())
  rules       AutomationRule[] // Relation to rules
}

model AutomationRule {
  id            Int      @id @default(autoincrement())
  walletAddress String
  privateKey    String   // <--- Added for Flashbots signing
  chain         String
  type          String   // AUTO_BURN, AUTO_RECOVERY
  active        Boolean  @default(true)
  targetBalance String?
  createdAt     DateTime @default(now())
  wallet        Wallet   @relation(fields: [walletAddress], references: [address])

  @@index([walletAddress, active])
}

// ... Keep ApiKey, Payment, RecoveryAttempt as they are
model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  wallet    String   @unique
  plan      String
  createdAt DateTime @default(now())
  usage     Int      @default(0)
  @@index([wallet])
}

model Payment {
  id        String   @id @default(cuid())
  wallet    String
  txHash    String?  @unique
  amount    Float
  chain     String
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([wallet])
}

model RecoveryAttempt {
  id                String   @id @default(cuid())
  walletAddress     String
  tokenCount        Int
  estimatedTotalUsd String
  status            String   
  createdAt         DateTime @default(now())
  @@index([walletAddress])
}

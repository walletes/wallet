generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
 
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  wallet    String   @unique
  plan      String
  createdAt DateTime @default(now())
  usage     Int      @default(0)
}

model Payment {
  id        String   @id @default(cuid())
  wallet    String
  txHash    String?  @unique
  amount    Float
  chain     String
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
}
